OPENCLAW_HOME="/root/.openclaw"
OPENCLAW_WORKSPACE="/root/.openclaw/workspace"
BACKUP_DIR="/root/backups/openclaw"
GIT_REMOTE="origin"
GIT_BRANCH="main"
LOG_DIR="/root/logs/openclaw-backup"
BORG_REPO="/root/backups/borg/openclaw"
BORG_PASSPHRASE="CHANGE-ME-TO-SOMETHING-SECURE"
KEEP_DAILY=7
KEEP_WEEKLY=4
KEEP_MONTHLY=3
